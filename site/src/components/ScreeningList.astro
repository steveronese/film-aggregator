---
import type { Cinema, Film, Screening } from '../lib/data';
import { fmtDate, fmtTime, langLabel, groupByDay } from '../lib/data';
import { langKey } from '../lib/i18n';

interface Props {
  screenings: Screening[];
  cinemas: Map<string, Cinema>;
  films: Map<number, Film>;
  // 'film' page → primary label is the cinema; 'cinema' page → primary label is the film.
  show: 'film' | 'cinema';
}
const { screenings, cinemas, films, show } = Astro.props;
const days = groupByDay(screenings);

function primary(s: Screening): { ttl: string; ttlEn: string; href: string | null } {
  if (show === 'film') {
    const c = cinemas.get(s.cinema_id);
    const name = c?.name ?? s.cinema_id;
    return { ttl: name, ttlEn: name, href: `/cinema/${s.cinema_id}` }; // venue names aren't translated
  }
  const f = s.tmdb_id != null ? films.get(s.tmdb_id) : undefined;
  if (f) return { ttl: f.title, ttlEn: f.title_en ?? f.title, href: `/film/${f.tmdb_id}` };
  return { ttl: s.raw_title, ttlEn: s.raw_title, href: null };
}
---

<div class="sched">
  {days.length === 0 && <p class="empty" data-i18n="screening.empty">Nessuna proiezione in programma al momento.</p>}
  {days.map(([day, list]) => (
    <div class="day-group">
      <div class="day-head" data-date={day}>{fmtDate(day + 'T00:00:00')}</div>
      {list.map((s) => {
        const p = primary(s);
        const lbl = langLabel(s.language);
        return (
          <div class="show-row">
            <span class="time">{fmtTime(s.start)}</span>
            <span class="where">
              {p.href
                ? <a class="ttl" href={p.href} data-it={p.ttl} data-en={p.ttlEn}>{p.ttl}</a>
                : <span class="ttl" data-it={p.ttl} data-en={p.ttlEn}>{p.ttl}</span>}
              {(s.hall || (show === 'cinema' && s.tmdb_id == null)) && (
                <span class="sub">
                  {s.hall}
                  {show === 'cinema' && s.tmdb_id == null && (
                    <>{s.hall ? ' · ' : ''}<span data-i18n="screening.unrecognized">non riconosciuto</span></>
                  )}
                </span>
              )}
            </span>
            {lbl && <span class={`pill ${s.language === 'dubbed' ? 'dub' : ''}`} data-i18n={langKey(s.language)}>{lbl}</span>}
            {s.booking_url && <a class="book" href={s.booking_url} target="_blank" rel="noopener" data-i18n="screening.tickets">Biglietti</a>}
          </div>
        );
      })}
    </div>
  ))}
</div>
