---
import Layout from '../../layouts/Layout.astro';
import ScreeningList from '../../components/ScreeningList.astro';
import {
  getCinemas, screeningsByCinema, cinemasById, filmsById, sortByStart,
} from '../../lib/data';

export function getStaticPaths() {
  return getCinemas().map((cinema) => ({ params: { id: cinema.id }, props: { cinema } }));
}

const { cinema } = Astro.props;
const scr = sortByStart(screeningsByCinema().get(cinema.id) ?? []);
const cinemas = cinemasById();
const films = filmsById();

const mapsUrl = cinema.address
  ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${cinema.name} ${cinema.address}`)}`
  : null;
---

<Layout title={`${cinema.name} — programmazione — SchermoMilano`}>
  <div class="detail" style="grid-template-columns: 1fr;">
    <div>
      <h1>{cinema.name}</h1>
      <p class="tagline">{[cinema.neighborhood, cinema.address].filter(Boolean).join(' · ')}</p>
      <div class="chiprow">
        {cinema.website && <a class="tag" href={cinema.website} target="_blank" rel="noopener" data-i18n="cinema.website">Sito ufficiale ↗</a>}
        {mapsUrl && <a class="tag" href={mapsUrl} target="_blank" rel="noopener" data-i18n="cinema.map">Mappa ↗</a>}
      </div>
    </div>
  </div>

  <section class="sched">
    <h2 data-i18n="cinema.nowShowing">In programmazione</h2>
    <ScreeningList screenings={scr} cinemas={cinemas} films={films} show="cinema" />
  </section>

  <a class="backlink" href="/" data-i18n="back.films">← Tutti i film</a>
</Layout>
