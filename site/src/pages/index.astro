---
import Layout from '../layouts/Layout.astro';
import FilmCard from '../components/FilmCard.astro';
import { getFilms, getCinemas, screeningsByFilm, cinemasById, sortByStart } from '../lib/data';

const films = getFilms();
const cinemas = getCinemas();
const cinMap = cinemasById();
const byFilm = screeningsByFilm();

// Films that have upcoming screenings, sorted by soonest screening.
const items = films
  .map((film) => ({ film, scr: sortByStart(byFilm.get(film.tmdb_id) ?? []) }))
  .filter((x) => x.scr.length > 0)
  .sort((a, b) => a.scr[0].start.localeCompare(b.scr[0].start));

const cinemasWithShows = cinemas.filter((c) => items.some((i) => i.scr.some((s) => s.cinema_id === c.id)));
---

<Layout
  title="SchermoMilano — film nelle sale di Milano"
  description="Cosa c'è al cinema a Milano: film d'essai, rassegne e versioni originali, tutto in un posto."
>
  <section class="intro">
    <h1>Cosa c'è al cinema a Milano</h1>
    <p>
      I film nelle sale della città — con un occhio di riguardo per le rassegne, le versioni
      originali e i titoli più difficili da trovare. Scegli un giorno, una sala, o filtra solo le
      proiezioni in lingua originale.
    </p>
  </section>

  <div class="filters">
    <div class="chips" role="group" aria-label="Giorno">
      <button class="chip" data-day="all" aria-pressed="true">Tutti</button>
      <button class="chip" data-day="today" aria-pressed="false">Oggi</button>
      <button class="chip" data-day="tomorrow" aria-pressed="false">Domani</button>
      <button class="chip" data-day="weekend" aria-pressed="false">Weekend</button>
    </div>
    <select class="control" id="cinema-filter" aria-label="Sala">
      <option value="all">Tutte le sale</option>
      {cinemasWithShows.map((c) => <option value={c.id}>{c.name}</option>)}
    </select>
    <label class="toggle"><input type="checkbox" id="vo-filter" /> Solo versione originale</label>
  </div>

  <p class="count" id="count"></p>

  <div class="grid" id="grid">
    {items.map((x) => <FilmCard film={x.film} screenings={x.scr} cinemas={cinMap} />)}
  </div>
  <p class="empty" id="empty" hidden>Nessun film con questi filtri. Prova ad allargare la ricerca.</p>
</Layout>

<script>
  const grid = document.getElementById('grid')!;
  const cards = Array.from(grid.querySelectorAll<HTMLAnchorElement>('.film-card'));
  const dayChips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip[data-day]'));
  const cinemaSel = document.getElementById('cinema-filter') as HTMLSelectElement;
  const voChk = document.getElementById('vo-filter') as HTMLInputElement;
  const count = document.getElementById('count')!;
  const empty = document.getElementById('empty')!;

  let day = 'all';

  const iso = (d: Date) => `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

  function allowedDays(): Set<string> | null {
    const now = new Date();
    if (day === 'all') return null;
    if (day === 'today') return new Set([iso(now)]);
    if (day === 'tomorrow') {
      const t = new Date(now); t.setDate(t.getDate() + 1);
      return new Set([iso(t)]);
    }
    // weekend: upcoming Saturday + Sunday
    const set = new Set<string>();
    for (let i = 0; i < 7; i++) {
      const d = new Date(now); d.setDate(d.getDate() + i);
      if (d.getDay() === 6 || d.getDay() === 0) set.add(iso(d));
    }
    return set;
  }

  function apply() {
    const days = allowedDays();
    const cinema = cinemaSel.value;
    const voOnly = voChk.checked;
    let shown = 0;
    for (const card of cards) {
      const cardDates = (card.dataset.dates ?? '').split(',');
      const cardCinemas = (card.dataset.cinemas ?? '').split(',');
      const okDay = !days || cardDates.some((d) => days.has(d));
      const okCinema = cinema === 'all' || cardCinemas.includes(cinema);
      const okVo = !voOnly || card.dataset.vo === '1';
      const visible = okDay && okCinema && okVo;
      card.hidden = !visible;
      if (visible) shown++;
    }
    count.textContent = `${shown} film in programmazione`;
    empty.hidden = shown !== 0;
  }

  dayChips.forEach((chip) => chip.addEventListener('click', () => {
    day = chip.dataset.day!;
    dayChips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
    apply();
  }));
  cinemaSel.addEventListener('change', apply);
  voChk.addEventListener('change', apply);
  apply();
</script>
