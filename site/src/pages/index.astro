---
import Layout from '../layouts/Layout.astro';
import FilmCard from '../components/FilmCard.astro';
import {
  getFilms, getCinemas, getScreenings, screeningsByFilm, cinemasById, filmsById,
  screeningsByCinema, sortByStart, groupByDay, fmtDate, fmtTime, langLabel, isOriginal,
} from '../lib/data';
import { langKey } from '../lib/i18n';

const films = getFilms();
const cinemas = getCinemas();
const cinMap = cinemasById();
const filmMap = filmsById();
const byFilm = screeningsByFilm();
const byCinema = screeningsByCinema();

// --- All-films view ---
const filmItems = films
  .map((film) => ({ film, scr: sortByStart(byFilm.get(film.tmdb_id) ?? []) }))
  .filter((x) => x.scr.length > 0)
  .sort((a, b) => a.scr[0].start.localeCompare(b.scr[0].start));

const cinemasWithShows = cinemas.filter((c) => (byCinema.get(c.id) ?? []).length > 0);

// --- Venue-type view ---
const CATEGORIES: { key: string; label: string }[] = [
  { key: 'arthouse', label: "Sale d'essai" },
  { key: 'museum', label: 'Musei e fondazioni' },
  { key: 'openair', label: "Arene all'aperto" },
  { key: 'multiplex', label: 'Multisala' },
];
const venuesByCategory = CATEGORIES.map((cat) => ({
  ...cat,
  venues: cinemas
    .filter((c) => (c.category ?? 'multiplex') === cat.key)
    .map((c) => ({ cinema: c, count: (byCinema.get(c.id) ?? []).length }))
    .filter((v) => v.count > 0) // hide venues with no upcoming screenings (closed/off-season)
    .sort((a, b) => b.count - a.count || a.cinema.name.localeCompare(b.cinema.name)),
})).filter((cat) => cat.venues.length > 0);

// --- Calendar view ---
const days = groupByDay(getScreenings());
const todayKey = days[0]?.[0];
---

<Layout
  title="SchermoMilano — film nelle sale di Milano"
  description="Cosa c'è al cinema a Milano: film d'essai, rassegne e versioni originali, tutto in un posto."
>
  <section class="intro">
    <h1 data-i18n="home.title">Cosa c'è al cinema a Milano</h1>
  </section>

  <div class="views" role="tablist">
    <button class="view-tab" data-view="film" aria-pressed="true" data-i18n="view.films">Tutti i film</button>
    <button class="view-tab" data-view="venues" aria-pressed="false" data-i18n="view.venues">Per sala</button>
    <button class="view-tab" data-view="calendar" aria-pressed="false" data-i18n="view.calendar">Calendario</button>
    <a class="view-tab" href="/mappa" data-i18n="view.map">Mappa</a>
  </div>

  <div class="filters" id="filters">
    <select class="control" id="cinema-filter" aria-label="Sala">
      <option value="all" data-i18n="filter.allVenues">Tutte le sale</option>
      {cinemasWithShows.map((c) => <option value={c.id}>{c.name}</option>)}
    </select>
    <label class="toggle"><input type="checkbox" id="vo-filter" /> <span data-i18n="filter.voOnly">Solo versione originale</span></label>
    <span class="count" id="count"></span>
  </div>

  {/* VIEW: all films */}
  <div data-panel="film">
    <div class="grid" id="grid">
      {filmItems.map((x) => <FilmCard film={x.film} screenings={x.scr} cinemas={cinMap} />)}
    </div>
    <p class="empty" id="empty-film" hidden data-i18n="empty.films">Nessun film con questi filtri.</p>
  </div>

  {/* VIEW: by venue type */}
  <div data-panel="venues" hidden>
    {venuesByCategory.map((cat) => (
      <details class="venue-group day-detail" open>
        <summary><span data-i18n={`cat.${cat.key}`}>{cat.label}</span> <span class="day-n">{cat.venues.length}</span></summary>
        <ul class="cinema-list">
          {cat.venues.map((v) => (
            <li class="cinema-row">
              <a href={`/cinema/${v.cinema.id}`}>
                <span class="name">{v.cinema.name}</span>
                <span class="meta">
                  {v.cinema.neighborhood && <>{v.cinema.neighborhood}{' · '}</>}
                  <span data-count="screening" data-n={v.count}>{v.count} proiezioni</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </div>

  {/* VIEW: calendar (collapsible by day) */}
  <div data-panel="calendar" hidden>
    {days.map(([day, list]) => (
      <details class="day-detail" open={day === todayKey}>
        <summary><span data-date={day}>{fmtDate(day + 'T00:00:00')}</span> <span class="day-n">{list.length}</span></summary>
        <div class="day-body">
          {list.map((s) => {
            const film = s.tmdb_id != null ? filmMap.get(s.tmdb_id) : undefined;
            const lbl = langLabel(s.language);
            const cinema = cinMap.get(s.cinema_id);
            return (
              <div class="show-row" data-cinema={s.cinema_id} data-vo={isOriginal(s.language) ? '1' : '0'}>
                <span class="time">{fmtTime(s.start)}</span>
                <span class="where">
                  {film
                    ? <a class="ttl" href={`/film/${film.tmdb_id}`} data-it={film.title} data-en={film.title_en ?? film.title}>{film.title}</a>
                    : <span class="ttl">{s.raw_title}</span>}
                  <span class="sub">{cinema?.name ?? s.cinema_id}</span>
                </span>
                {lbl && <span class={`pill ${s.language === 'dubbed' ? 'dub' : ''}`} data-i18n={langKey(s.language)}>{lbl}</span>}
              </div>
            );
          })}
        </div>
      </details>
    ))}
  </div>
</Layout>

<script>
  import { UI } from '../lib/i18n';
  const lang = () => ((window as any).__lang === 'en' ? 'en' : 'it');
  const unit = (n: number, base: string) => UI[lang()][`unit.${base}${n === 1 ? '' : 's'}`] ?? '';

  const tabs = Array.from(document.querySelectorAll<HTMLElement>('.view-tab[data-view]'));
  const panels = new Map<string, HTMLElement>();
  document.querySelectorAll<HTMLElement>('[data-panel]').forEach((p) => panels.set(p.dataset.panel!, p));
  const filters = document.getElementById('filters')!;
  const cinemaSel = document.getElementById('cinema-filter') as HTMLSelectElement;
  const voChk = document.getElementById('vo-filter') as HTMLInputElement;
  const count = document.getElementById('count')!;
  const emptyFilm = document.getElementById('empty-film')!;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.film-card'));
  const rows = Array.from(document.querySelectorAll<HTMLElement>('.show-row'));

  let view = 'film';

  function applyFilters() {
    const cinema = cinemaSel.value;
    const voOnly = voChk.checked;
    if (view === 'film') {
      let shown = 0;
      for (const card of cards) {
        const okCinema = cinema === 'all' || (card.dataset.cinemas ?? '').split(',').includes(cinema);
        const okVo = !voOnly || card.dataset.vo === '1';
        const visible = okCinema && okVo;
        card.hidden = !visible;
        if (visible) shown++;
      }
      count.textContent = `${shown} ${unit(shown, 'film')}`;
      emptyFilm.hidden = shown !== 0;
    } else if (view === 'calendar') {
      let shown = 0;
      for (const row of rows) {
        const okCinema = cinema === 'all' || row.dataset.cinema === cinema;
        const okVo = !voOnly || row.dataset.vo === '1';
        const visible = okCinema && okVo;
        row.hidden = !visible;
        if (visible) shown++;
      }
      // hide day groups that ended up empty
      document.querySelectorAll<HTMLElement>('.day-detail').forEach((d) => {
        const any = d.querySelector('.show-row:not([hidden])');
        d.hidden = !any;
      });
      count.textContent = `${shown} ${unit(shown, 'screening')}`;
    }
  }

  function setView(next: string) {
    view = next;
    tabs.forEach((t) => t.setAttribute('aria-pressed', String(t.dataset.view === next)));
    panels.forEach((p, key) => (p.hidden = key !== next));
    filters.hidden = next === 'venues'; // filters apply to film & calendar only
    applyFilters();
  }

  tabs.forEach((t) => t.addEventListener('click', () => setView(t.dataset.view!)));
  cinemaSel.addEventListener('change', applyFilters);
  voChk.addEventListener('change', applyFilters);
  document.addEventListener('langchange', applyFilters); // re-localise the count words
  setView('film');
</script>
